# ============================================
# Lead Generation Agent — Environment Template
# ============================================
# Copy this file to .env and fill in your values.
# Never commit your .env file — it is gitignored.
# ============================================

# ----- AI Providers -----
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_here

# ----- Email (SMTP/IMAP) -----
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
FROM_NAME=Your Name
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# ----- Outreach -----
CALENDLY_LINK=https://calendly.com/your-link/30min
TRACKING_BASE_URL=http://localhost:8080
TRACKING_SECRET=a_long_random_secret_string_here

# ----- Database -----
LEAD_DB_PATH=data/lead_bot.db

# ----- Owner / Notifications -----
OWNER_PHONE=+1234567890
OWNER_TIMEZONE=UTC
AI_MAX_RETRIES=3

# ----- WhatsApp -----
WHATSAPP_PROVIDER=web
D360_API_KEY=
D360_PHONE_NUMBER_ID=
D360_BASE_URL=https://waba-v2.360dialog.io
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SIGNING_SECRET=your_hmac_signing_secret

# ----- LinkedIn (optional) -----
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_DATA_DIR=data/linkedin

# ----- WhatsApp Data -----
WHATSAPP_DATA_DIR=data/whatsapp

# ----- Global Sources (optional) -----
APOLLO_API_KEY=
GITHUB_TOKEN=
PRODUCTHUNT_TOKEN=

# ----- Localization & Compliance -----
OUTREACH_LANGUAGE=auto
GDPR_MODE=false

# ----- Reliability -----
PROXY_LIST=
