GROQ_API_KEY=your_groq_api_key_here
GOOGLE_AI_API_KEY=alternative_google_ai_key

EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

FROM_NAME=Digital Marketing Expert
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

CALENDLY_LINK=https://calendly.com/your-link/30min

LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

TRACKING_BASE_URL=http://localhost:8080
TRACKING_SECRET=change-me-generate-a-long-random-string-here
LEAD_DB_PATH=data/lead_bot.db

OWNER_PHONE=+1234567890
OWNER_TIMEZONE=UTC              # IANA tz e.g. America/New_York — gates daily report + alert quiet-hours (agent.py)

AI_MAX_RETRIES=3

# ===== GLOBAL mode =====================================================
# --- Lead sources (Section 1) ---
APOLLO_API_KEY=                 # Apollo.io people search (free tier: no email reveal)
GITHUB_TOKEN=                   # optional; raises GitHub API limit 60/hr -> 5000/hr
PRODUCTHUNT_TOKEN=              # ProductHunt GraphQL developer token

# --- WhatsApp Business API (Section 4) ---
WHATSAPP_PROVIDER=web           # "api" (360dialog) or "web" (Playwright fallback)
D360_API_KEY=                   # 360dialog API key (paid WABA required)
D360_PHONE_NUMBER_ID=           # 360dialog sender phone number id
# D360_BASE_URL=https://waba-v2.360dialog.io   # override if needed

# --- WhatsApp Webhook Auth (Section 4) ---
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_WEBHOOK_SIGNING_SECRET=your_hmac_signing_secret

# --- Language (Section 5) ---
OUTREACH_LANGUAGE=auto          # auto | english | native

# --- Compliance (Section 6) ---
GDPR_MODE=false                 # true adds a data-processing notice to emails

# --- Reliability (Section 8) ---
PROXY_LIST=                     # comma-separated ip:port:user:pass for rotation